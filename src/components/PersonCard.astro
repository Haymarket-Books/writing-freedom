---
import { Image } from "astro:assets";
import { urlForImage } from "@lib/sanity/urlForImage";
import joinNames from "../utils/joinNames";
import buildFellowHref from "../utils/buildFellowHref";
import type { CollectionEntry } from "astro:content";

type Props = {
  person: CollectionEntry<"fellows"> | CollectionEntry<"teamMembers">;
};

const { person } = Astro.props;
---

<article class="flow">
  {
    person.data.type === "teamMember" ? (
      <Fragment>
        <div class="team-member | text | flow">
          <h3>{joinNames(person.data.name)}</h3>
          <p class="small-title">{person.data.category?.name}</p>
        </div>
      </Fragment>
    ) : (
      <Fragment>
        <a
          class="img-wrapper"
          href={buildFellowHref(person as CollectionEntry<"fellows">)}
        >
          <Image
            class="headshot lqip-preview"
            src={urlForImage(person.data.image!)
              .width(400)
              .height(500)
              .auto("format")
              .url()}
            alt={person.data.image?.alt || ""}
            width={400}
            height={500}
            format="webp"
            style={`background-image: url(${person?.data.image?.asset.metadata.lqip})`}
          />
          <Image
            class="headshot-mobile lqip-preview"
            src={urlForImage(person.data.image!)
              .width(400)
              .height(500)
              .auto("format")
              .url()}
            alt={person.data.image?.alt || ""}
            width={500}
            height={400}
            format="webp"
            style={`background-image: url(${person?.data.image?.asset.metadata.lqip})`}
          />
        </a>
        <div class="fellow | text | flow">
          <a href={buildFellowHref(person as CollectionEntry<"fellows">)}>
            <h3>{joinNames(person.data.name)}</h3>
          </a>
          <p class="small-title">
            {(person as CollectionEntry<"fellows">).data.fellowshipYear.year}{" "}
            Fellow
          </p>
        </div>
      </Fragment>
    )
  }
</article>

<style>
  article {
    container: personCard / inline-size;
    --underline-color: color-mix(
      in srgb,
      var(--color-primary-base),
      transparent 50%
    );

    &.flow {
      --flow-space: 0.75rem;
    }

    & > a {
      overflow: hidden;

      &:hover img {
        transform: scale(1.05);
      }

      &:hover + .text a {
        text-decoration: underline var(--underline-color);
      }
    }
  }

  .img-wrapper {
    border-radius: var(--rounded-corners-small);
    filter: grayscale(100%) brightness(1.1) contrast(1.1);
    transition: all 1s;

    &:hover {
      filter: grayscale(0%);
    }
  }

  :is(.headshot, .headshot-mobile) {
    object-fit: cover;
    border-radius: var(--rounded-corners-small);
    transition: all 0.3s ease-out;
  }

  .headshot {
    aspect-ratio: 4/5;
  }

  .headshot-mobile {
    aspect-ratio: 4/5;
    display: none;
  }

  .team-member h3 {
    font-size: var(--step-1);
  }

  .fellow h3 {
    font-size: min(var(--step-1), 7cqi);
  }

  .text {
    &.flow {
      --flow-space: 0.5rem;
    }

    & .small-title {
      opacity: var(--text-opacity-shade);
      font-size: 12px;
    }

    & a {
      transition: all 0.2s ease-out;
      text-decoration: none;

      &:hover {
        text-decoration: underline var(--underline-color);
      }
    }
  }

  @media (max-width: 640px) {
    .headshot-mobile {
      display: block;
    }

    .headshot {
      display: none;
    }
  }

  @media (prefers-reduced-motion) {
    article {
      & > a {
        &:hover img {
          transform: unset;
        }
      }
    }
  }

  @container personCard (width > 350px) {
    .fellow h3 {
      font-size: max(var(--step-2), 6cqi);
    }
  }
</style>
