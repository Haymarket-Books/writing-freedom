---
import PersonCard from "../PersonCard.astro";
import FellowsFilterYear from "../FellowsFilterYear.astro";
import type { CollectionEntry } from "astro:content";

type Props = {
  title: string;
  listTitle?: string;
  fellows: CollectionEntry<"fellows">[];
};

const { title, listTitle = "Fellows", fellows } = Astro.props;
---

<div class="content-wrapper flow">
  <h1 class="with-mark">{title}</h1>
  <FellowsFilterYear />
  <section class="flow">
    <!-- <h2 class="sr-only">All Fellows</h2> -->
    <h2 class="sr-only">{listTitle}</h2>
    <div class="index-section | fellows-grid | responsive-grid">
      {
        fellows
          .sort((a, b) => {
            if (a.data.name.lastName === b.data.name.lastName) {
              return a.data.name.firstName > b.data.name.firstName ? 1 : -1;
            }
            return a.data.name.lastName > b.data.name.lastName ? 1 : -1;
          })
          .map((fellow) => {
            return <PersonCard person={fellow} />;
          })
      }
    </div>
  </section>
  <!-- <fellow-filter class="flow">
    <FellowsFilters years={filterYears} categories={filterCategories} />
    <section class="flow">
      <h2>All Fellows</h2>
      <div class="fellows-grid | responsive-grid">
        {
          content?.map((fellow) => {
            return <PersonCard person={fellow} />;
          })
        }
      </div>
    </section>
  </fellow-filter> -->
</div>

<style>
  .content-wrapper {
    margin-block: var(--section-spacer);

    &.flow {
      --flow-space: 3rem;
    }
  }

  /* h1 {
    max-width: 16ch;
  } */

  h2 {
    font-size: var(--step-2);
  }

  section {
    margin-block: var(--space-m);

    &.flow {
      --flow-space: 1.5rem;
    }
  }

  .responsive-grid {
    /* --grid-gap: 2rem; */
    --item-min-width: 16rem;
    /* --item-max-width: 18rem; */
    grid-row-gap: 4rem;
    grid-column-gap: 2rem;
    /*--item-min-width: 12rem; 
    --item-max-width: 14rem; */
  }
</style>

