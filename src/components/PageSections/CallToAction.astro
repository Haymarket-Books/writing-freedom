---
import ButtonLink from "@components/ButtonLink.astro";
import { urlForImage } from "@lib/sanity/urlForImage";
import { Image } from "astro:assets";
import type { CTASection } from "@content/schemaFragments/sanityComponents";

type Props = {
  content: CTASection;
};

const { content } = Astro.props;
---

<article id={content.slug}>
  <div class="wrapper">
    <div class="text | flow">
      <h2 class="balanced with-mark">{content.heading}</h2>
      <p>{content.text}</p>
      {
        content.linkObject && (
          <ButtonLink linkObject={content.linkObject} withArrow />
        )
      }
    </div>
  </div>
  {
    content.image && (
      <Image
        class="bg-image lqip-preview"
        src={urlForImage(content.image)
          .width(1920)
          .height(1080)
          .auto("format")
          .url()}
        width={1920}
        height={1080}
        alt={content.image.asset || ""}
        format="webp"
        style={`background-image: url(${content.image.asset.metadata.lqip})`}
      />
    )
  }
</article>

<style>
  article {
    position: relative;
    overflow: hidden;
  }

  .wrapper {
    margin-inline: var(--gutter);
  }

  .text {
    position: relative;
    z-index: 2;
    max-width: 55rem;
    margin-block: var(--section-spacer);
    margin-inline: auto;
    background: var(--color-white);
    border-radius: var(--rounded-corners-small);
    padding: 6rem 4rem 4rem;
    box-shadow: var(--shadow-regular);
  }

  @media (max-width: 768px) {
    .text {
      padding: 4rem 2rem 2rem;
    }
  }
</style>
