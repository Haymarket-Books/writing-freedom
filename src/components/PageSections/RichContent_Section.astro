---
import RichContent from "@components/RichContent.astro";
import "../../styles/rich-content.css";
import type { RichContentSection as RichContentSectionType } from "@content/schemaFragments/sanityComponents";

type Props = {
  content: RichContentSectionType;
};

const { content } = Astro.props;
---

<section class="content-wrapper">
  <div class="rich-content">
    <RichContent content={content.blocks} />
  </div>
</section>

<style>
  section {
    margin-block: var(--section-spacer);
  }

  .rich-content {
    margin-inline: auto;
    max-width: var(--paragraph-measure);
  }

  @media (max-width: 768px) {
    section {
      margin-block-start: calc((var(--section-spacer) * -1) * 0.75);
    }
  }
</style>
