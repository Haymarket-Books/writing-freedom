---
import { Image } from "astro:assets";
import ButtonLink from "@components/ButtonLink.astro";
import { urlForImage } from "@lib/sanity/urlForImage";
import type { SponsorsSection } from "@content/schemaFragments/sanityComponents";

type Props = {
  content: SponsorsSection;
};

const { content } = Astro.props;
---

<section class="sponsors-section | content-wrapper" id={content.slug}>
  <h2 class="center-all with-mark">{content.title}</h2>
  <div class="responsive-grid">
    {
      content.items.map((item) => {
        return (
          <article class="flow">
            {item.image && (
              <Image
                src={urlForImage(item.image)
                  .width(
                    Math.floor(
                      400 * item.image.asset.metadata.dimensions.aspectRatio,
                    ),
                  )
                  .height(400)
                  .auto("format")
                  .url()}
                alt={item.image.alt || ""}
                width={Math.floor(
                  400 * item.image.asset.metadata.dimensions.aspectRatio,
                )}
                height={400}
                format="webp"
              />
            )}
            <p>{item.text}</p>
            {item.linkObject && (
              <ButtonLink linkObject={item.linkObject} withArrow />
            )}
          </article>
        );
      })
    }
  </div>
</section>

<style>
  section {
    margin-block: var(--section-spacer);
  }

  h2 {
    font-size: var(--step-2);

    &::before {
      left: 50% !important;
      transform: translateX(-50%);
    }
  }

  h3 {
    font-size: var(--step-1);
  }

  .responsive-grid {
    --item-min-width: 20rem;
    --grid-gap: var(--space-2xl);
    margin-block-start: calc(var(--section-spacer) * 0.5);
  }

  article {
    &.flow {
      --flow-space: 2rem;
    }

    & img {
      height: 6rem;
      object-fit: contain;
      /* max-height: 8rem; */
      /* margin-inline: auto; */
      width: auto;
      align-self: flex-start;
    }
  }

  @media (max-width: 768px) {
    article {
      justify-content: center;

      &.flow {
        align-items: center;
        text-align: center;
      }

      & img {
        margin: auto;
        max-height: 6rem;
        object-fit: contain;
      }
    }
  }
</style>
